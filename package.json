{
  "name": "nexus",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/ui",
    "apps/site",
    "packages/protocol"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names backend,ui \"pnpm --filter @nexus/backend dev\" \"pnpm --filter @nexus/ui dev -- --host ${NEXUS_HOST:-$(node --env-file-if-exists=.env -p 'process.env.NEXUS_HOST || \"127.0.0.1\"' 2>/dev/null)}\"",
    "dev:backend": "pnpm --filter @nexus/backend dev",
    "dev:ui": "pnpm --filter @nexus/ui dev -- --host ${NEXUS_HOST:-$(node --env-file-if-exists=.env -p 'process.env.NEXUS_HOST || \"127.0.0.1\"' 2>/dev/null)}",
    "dev:site": "pnpm --filter @nexus/site dev",
    "build": "pnpm --filter @nexus/protocol build && pnpm --filter @nexus/backend build && pnpm --filter @nexus/ui build && pnpm --filter @nexus/site build",
    "prod": "pnpm build && pnpm prod:start",
    "prod:start": "concurrently --kill-others-on-fail --names backend,ui \"NODE_ENV=production NEXUS_PORT=47287 pnpm --filter @nexus/backend start\" \"pnpm --filter @nexus/ui preview -- --port 47289 --strictPort --host ${NEXUS_HOST:-$(node --env-file-if-exists=.env -p 'process.env.NEXUS_HOST || \"127.0.0.1\"' 2>/dev/null)}\"",
    "prod:daemon": "node scripts/prod-daemon.mjs",
    "prod:restart": "node scripts/prod-daemon-restart.mjs",
    "test": "pnpm --filter @nexus/backend test && pnpm --filter @nexus/ui test"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.6",
      "@tanstack/router-generator>zod": "3.25.76",
      "@tanstack/router-plugin>zod": "3.25.76",
      "@tanstack/start-plugin-core>zod": "3.25.76"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
